# Required
API_KEY=your_api_key_here

# Optional: OpenAI-compatible endpoint/model
OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
OPENAI_MODEL=glm-4.7

# Optional: Gemini image generation (required only for nano_banana_image plugin)
GEMINI_API_KEY=

# Optional: Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_CHAT_IDS=

# Optional: Runtime paths
ABRAXAS_SKILLS_DIR=src/skills
ABRAXAS_MEMORY_DIR=src/memory
ABRAXAS_NOUS_PATH=src/core/NOUS.md

# Optional: Model / memory behavior
ABRAXAS_MEMORY_TZ=Asia/Shanghai
ABRAXAS_MEMORY_DAILY_SYNC_TIME=02:00
ABRAXAS_MEMORY_MICRO_SYNC_TIMES=10:00,13:00,16:00,19:00,22:00
ABRAXAS_MEMORY_WEEKLY_COMPOUND_TIME=22:00
ABRAXAS_MEMORY_WEEKLY_COMPOUND_WEEKDAY=6

ABRAXAS_QMD_COMMAND=qmd
ABRAXAS_QMD_TIMEOUT_SEC=30
ABRAXAS_MEMORY_TOP_K=6
ABRAXAS_MEMORY_MAX_INJECT_CHARS=4000

ABRAXAS_AUTO_COMPACT_MAX_TOKENS=12000
ABRAXAS_AUTO_COMPACT_KEEP_LAST_MESSAGES=12
ABRAXAS_AUTO_COMPACT_INSTRUCTIONS=
ABRAXAS_AUTO_BRAINDUMP_ENABLED=true
ABRAXAS_NOUS_TZ=Asia/Shanghai
